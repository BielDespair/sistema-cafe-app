# Copie este arquivo para ".env" e ajuste os valores antes de rodar em produção.

# Chave usada para assinar os tokens JWT. Gere uma bem aleatória, por exemplo:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque-esta-chave-antes-de-ir-para-producao

# Tempo de validade do token de login, em minutos (480 = 8h, um turno de trabalho)
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Banco de dados. Por padrão usa SQLite em arquivo local.
# Para Postgres: postgresql+psycopg2://usuario:senha@host:5432/estoque
DATABASE_URL=sqlite:///./estoque.db

# Origens do frontend liberadas no CORS, separadas por vírgula
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:4173
